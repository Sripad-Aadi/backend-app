<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Users</h1>
    <ol>
        <% users.forEach(user=>{ %>
            <li><%= user.name %>-
                <%= user.email %>-
                <%= user.role %>
                <p><a href="/users/<%= user._id %>/edit">Edit</a></p>
                <p><a href="/users/<%= user._id %>/delete">Delete</a></p>
            </li>
        <%})
        %>
    </ol>
</body>
</html>