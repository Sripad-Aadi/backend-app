<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Products Admin Page</h2>
    <p><a href="/products/add">Add product</a></p>
    <ol>
        <% products.forEach(product=>{ %>
            <li><%= product.name %>-
                <%= product.desc %>-
                <%= product.rating %>-
                <%= product.imageURL %>-
                <%= product.price %>-
                <p><a href="/products/<%= product._id %>/edit">Edit</a></p>
                <p><a href="/products/<%= product._id %>/delete">Delete</a></p>
            </li>
        <%})
        %>
    </ol>
</body>
</html>